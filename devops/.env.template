# =============================================================================
# Electrica Ventas - Template de variables de entorno
# Copiar este archivo a /etc/electrica/.env y completar los valores
# NUNCA subir el archivo .env real a Git
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
WS_PORT=3001

# URL del frontend (para CORS y redirecciones)
FRONTEND_URL=https://app.electrica.mx

# -----------------------------------------------------------------------------
# BASE DE DATOS - PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://electrica_user:CAMBIAR_PASSWORD@localhost:5432/electrica_ventas

# -----------------------------------------------------------------------------
# CACHÉ / COLAS - Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# AUTENTICACIÓN JWT
# Generar con: openssl rand -hex 64
# JWT_SECRET: tokens de acceso (15 min)
# JWT_REFRESH_SECRET: tokens de refresco (7 días)
# -----------------------------------------------------------------------------
JWT_SECRET=GENERAR_CON_openssl_rand_hex_64
JWT_REFRESH_SECRET=GENERAR_CON_openssl_rand_hex_64_DIFERENTE

# -----------------------------------------------------------------------------
# CIFRADO
# Clave de 32 bytes en hex para cifrar api_keys almacenadas en DB
# Generar con: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# WHATSAPP - 360dialog
# Base URL de la API
# Las api_keys por canal se almacenan en DB (tabla canales, campo api_key_enc)
# y se inyectan en runtime; estas variables son fallback para desarrollo
# -----------------------------------------------------------------------------
WA_BASE_URL=https://waba.360dialog.io/v1

# Líneas WhatsApp (1 a 14) — valor PENDIENTE hasta alta en 360dialog
WA_API_KEY_LINEA_01=PENDIENTE
WA_API_KEY_LINEA_02=PENDIENTE
WA_API_KEY_LINEA_03=PENDIENTE
WA_API_KEY_LINEA_04=PENDIENTE
WA_API_KEY_LINEA_05=PENDIENTE
WA_API_KEY_LINEA_06=PENDIENTE
WA_API_KEY_LINEA_07=PENDIENTE
WA_API_KEY_LINEA_08=PENDIENTE
WA_API_KEY_LINEA_09=PENDIENTE
WA_API_KEY_LINEA_10=PENDIENTE
WA_API_KEY_LINEA_11=PENDIENTE
WA_API_KEY_LINEA_12=PENDIENTE
WA_API_KEY_LINEA_13=PENDIENTE
WA_API_KEY_LINEA_14=PENDIENTE

# Secreto para validar firma HMAC de webhooks de 360dialog
# Se obtiene en el panel de 360dialog al registrar el webhook
WA_WEBHOOK_SECRET=PENDIENTE

# -----------------------------------------------------------------------------
# EMAIL SALIENTE - SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@electrica.mx
SMTP_PASS=CAMBIAR_PASSWORD_SMTP

# Remitente visible en los correos
SMTP_FROM_NAME=Electrica Ventas
SMTP_FROM_EMAIL=no-reply@electrica.mx

# -----------------------------------------------------------------------------
# EMAIL ENTRANTE - IMAP
# (para recibir respuestas de clientes y crear mensajes en el CRM)
# -----------------------------------------------------------------------------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=ventas@electrica.mx
IMAP_PASS=CAMBIAR_PASSWORD_IMAP

# Carpeta IMAP a monitorear
IMAP_MAILBOX=INBOX

# Intervalo de polling en milisegundos (default: 60000 = 1 minuto)
IMAP_POLL_INTERVAL_MS=60000

# -----------------------------------------------------------------------------
# BULL BOARD - Panel de monitoreo de colas
# Accesible en: https://api.electrica.mx/api/admin/queues
# -----------------------------------------------------------------------------
BULL_BOARD_USER=admin
BULL_BOARD_PASS=CAMBIAR_PASSWORD_BULL_BOARD

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=/var/log/electrica
