# ── Server ─────────────────────────────────────
NODE_ENV=development
PORT=3000
WS_PORT=3001

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/electrica_ventas

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_256bit_secret
JWT_REFRESH_SECRET=change_me_to_another_random_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption key for API keys in DB ───────────
ENCRYPTION_KEY=exactly32charsecretkey!!change!!

# ── CORS ────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── SMTP (Nodemailer) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ventas@electrica.mx
SMTP_PASS=your_app_password_here
SMTP_FROM=ventas@electrica.mx

# ── IMAP (email polling) ────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=ventas@electrica.mx
IMAP_PASS=your_app_password_here

# ── Bull Board admin UI ─────────────────────────
BULL_BOARD_USER=admin
BULL_BOARD_PASS=change_me_admin_password

# ── Company info (used in PDF/emails) ───────────
EMPRESA_NOMBRE=Electrica Ventas S.A. de C.V.
EMPRESA_RFC=EVI000000XXX
EMPRESA_TELEFONO=+52 81 0000-0000
EMPRESA_DIRECCION=Av. Principal 100, Monterrey, N.L.
EMPRESA_EMAIL=contacto@electrica.mx
EMPRESA_LOGO_URL=

# ── API base URL (used for document links) ──────
API_BASE_URL=http://localhost:3000
